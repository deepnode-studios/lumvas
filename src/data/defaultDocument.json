            "fontSize": 42,
            "fontWeight": 600,
            "lineHeight": 1.3,
            "color": "primary"
          },
          {
            "id": "el_text05",
            "type": "text",
            "content": "Agents need a programmatic, pure-data approach to build UIs autonomously without relying on Markdown limitations or heavy visual editors.",
            "fontId": "body",
            "fontSize": 24,
            "lineHeight": 1.6,
            "color": "#8b949e"
          }
        ]
      },
      {
        "id": "sl_sol03",
        "alignItems": "center",
        "justifyContent": "center",
        "direction": "column",
        "padding": 80,
        "gap": 48,
