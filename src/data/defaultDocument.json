            "fontSize": 42,
            "fontWeight": 600,
            "lineHeight": 1.3,
            "color": "primary"
          },
          {
            "id": "el_text05",
            "type": "text",
            "content": "Agents need a programmatic, pure-data approach to build UIs autonomously without relying on Markdown limitations or heavy visual editors.",
            "fontId": "body",
            "fontSize": 24,
            "lineHeight": 1.6,
            "color": "#8b949e"
          }
        ]
      },
      {
        "id": "sl_sol03",
        "alignItems": "center",
        "justifyContent": "center",
        "direction": "column",
        "padding": 80,
        "gap": 48,
        "elements": [
          {
            "id": "el_text06",
            "type": "text",
            "content": "How It Works",
            "fontId": "header",
            "fontSize": 56,
            "fontWeight": 800,
            "textAlign": "center",
            "color": "primary"
          },
          {
            "id": "el_list01",
            "type": "list",
            "content": "Define global themes & upload core assets\nMap headings and layouts into strict JSON\nEngine renders Next.js components dynamically\nExport directly to social-ready images\nFeed JSON back to AI for instant iteration",
            "fontId": "body",
            "fontSize": 24,
            "fontWeight": 500,
            "lineHeight": 1.8,
            "color": "#e6edf3"
          }
        ]
      },
