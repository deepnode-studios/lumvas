          {
            "id": "el_text08",
            "type": "text",
            "content": "Built on the Next.js App Router using custom styling architecture. We maintain strict programmatic control over design tokens by entirely avoiding utility-class bloat.",
            "fontId": "body",
            "fontSize": 26,
            "lineHeight": 1.5,
            "color": "#8b949e"
          }
        ]
      },
      {
        "id": "sl_cta05",
        "alignItems": "center",
        "justifyContent": "center",
