        "padding": 100,
        "gap": 32,
        "style": {
          "backgroundColor": "#161b22"
        },
        "elements": [
          {
            "id": "el_icon03",
            "type": "icon",
            "iconName": "terminal",
            "iconSize": 48,
            "color": "secondary"
          },
