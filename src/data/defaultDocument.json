            "type": "icon",
            "iconName": "rocket",
            "iconSize": 64,
            "color": "primary"
          },
          {
            "id": "el_text09",
            "type": "text",
            "content": "Join the Movement",
            "fontId": "header",
            "fontSize": 56,
            "fontWeight": 800,
            "textAlign": "center",
            "lineHeight": 1.1,
            "color": "primary"
          },
          {
            "id": "el_text10",
            "type": "text",
            "content": "Help us build the common language for agents to build, modify, and iterate on visual documents.",
            "fontId": "body",
            "fontSize": 24,
            "textAlign": "center",
            "lineHeight": 1.5,
            "color": "#8b949e",
            "maxWidth": "80%"
          },
